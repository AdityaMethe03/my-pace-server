# ===============================
# = App config
# ===============================
spring.application.name=auth-app
server.port=8091
server.servlet.context-path=/app

# ===============================
# = Profile - dev/test/prod
# ===============================
spring.profiles.active=dev

# ===============================
# SWAGGER & OPENAPI
# ===============================
springdoc.api-docs.path=/api-docs
springdoc.swagger-ui.path=/swagger-ui.html
springdoc.swagger-ui.tagsSorter=alpha
springdoc.webjars.prefix=
app.swagger.server.urls=http://127.0.0.1:${server.port}${server.servlet.context-path:},http://localhost:${server.port}${server.servlet.context-path:}

# ===============================
# DATABASE(mongodb)
# ===============================
spring.mongodb.username=
spring.mongodb.password=
spring.mongodb.uri=mongodb+srv://${spring.mongodb.username}:${spring.mongodb.password}@authentication-app-clus.g4pysqu.mongodb.net/